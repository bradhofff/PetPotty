@page
@model PetPotty.Pages.HomeModel
@{
    ViewData["Title"] = "Home";
}

@if (TempData["StatusMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["StatusMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<h1>Pet Dashboard</h1>

@* ============================================================
   PETS SECTION
   ============================================================ *@
<style>
    .edit-pets-toggle {
        border: 2px solid #198754;
        color: #198754;
        background-color: transparent;
        transition: background-color 0.2s ease, border-color 0.2s ease, color 0.2s ease;
    }

    .edit-pets-toggle:hover {
        background-color: #198754;
        border-color: #198754;
        color: #fff;
    }

    .edit-pets-toggle.active {
        background-color: #198754;
        border-color: #198754;
        color: #fff;
    }

    .edit-pets-toggle.active:hover {
        background-color: #dc3545;
        border-color: #dc3545;
        color: #fff;
    }

    .task-notes-cell {
        white-space: normal;
        word-break: break-word;
        max-width: 360px;
    }

    /* ── Day separator rows in task tables ── */
    .task-day-separator td {
        background: rgba(244, 164, 96, 0.18);
        color: var(--pet-primary);
        font-weight: 700;
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 0.07em;
        padding: 0.3rem 0.75rem;
        border-top: 2px solid rgba(244, 164, 96, 0.4);
        border-bottom: 1px solid rgba(244, 164, 96, 0.25);
    }

    /* ── Quick log buttons ── */
    .quick-log-btn {
        width: 32px;
        height: 32px;
        border-radius: 8px;
        border: 1px solid rgba(244, 164, 96, 0.4);
        background: white;
        font-size: 1rem;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: background 0.15s ease, transform 0.1s ease, border-color 0.15s ease;
        padding: 0;
        line-height: 1;
        vertical-align: middle;
    }

    .quick-log-btn:hover {
        background: rgba(244, 164, 96, 0.15);
        border-color: var(--pet-secondary);
        transform: scale(1.1);
    }

    .quick-log-btn:active { transform: scale(0.95); }
</style>

<div class="d-flex align-items-center justify-content-between mb-3">
    <h2 class="mb-0">My Pets 🐾</h2>
    <div class="d-flex align-items-center gap-2">
        <button type="button" class="btn btn-sm edit-pets-toggle" id="togglePetActionsBtn" aria-pressed="false">
            Edit Pets
        </button>
        <button type="button" class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#addPetModal">
            + Add Pet
        </button>
    </div>
</div>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>Name</th>
            <th>Type</th>
            <th>Breed</th>
            <th>Age</th>
            <th>Birthdate</th>
            <th>Gender</th>
            <th class="pet-actions-col d-none">Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var pet in Model.Pets)
        {
            var petBirthdate = pet.Birthdate.ToString("yyyy-MM-dd");
            <tr>
                <td>@pet.Name</td>
                <td>@pet.Type</td>
                <td>@pet.Breed</td>
                <td>@pet.Age</td>
                <td>@pet.Birthdate.ToShortDateString()</td>
                <td>@pet.Gender</td>
                <td class="pet-actions-col d-none">
                    <button class="btn btn-sm btn-edit edit-pet-btn"
                            data-bs-toggle="modal"
                            data-bs-target="#editPetModal"
                            data-pet-id="@pet.PetID"
                            data-pet-name="@pet.Name"
                            data-pet-type="@pet.Type"
                            data-pet-breed="@pet.Breed"
                            data-pet-age="@pet.Age"
                            data-pet-birthdate="@petBirthdate"
                            data-pet-gender="@pet.Gender">
                        Edit
                    </button>
                </td>
            </tr>
        }
    </tbody>
</table>

@* ============================================================
   TASKS SECTION
   ============================================================ *@
<div class="d-flex align-items-center justify-content-between mb-3">
    <div class="d-flex align-items-center gap-3">
        <h2 class="mb-0">Tasks</h2>
        <a href="/Home?showAllTime=@(!Model.ShowAllTime)" class="btn btn-link p-0">
            @(Model.ShowAllTime ? "Show Past 24 Hours" : "Show All Time")
        </a>
        <span class="text-muted">(@(Model.ShowAllTime ? "All Time" : "Past 24 Hours"))</span>
    </div>
    <button type="button" class="btn btn-sm edit-pets-toggle" id="toggleTaskActionsBtn" aria-pressed="false">
        Edit Tasks
    </button>
</div>

@* Accordion — no data-bs-parent so multiple can stay open simultaneously *@
<div class="accordion" id="tasksAccordion">
    @{
        var petIndex = 0;
    }
    @foreach (var pet in Model.Pets)
    {
        var isExpanded = petIndex < 2;
        petIndex++;
        var taskCount = Model.PetTasks[pet.PetID].Count;
        var collapseId  = $"collapse-{pet.PetID}";
        var headingId   = $"heading-{pet.PetID}";

        <div class="accordion-item">
            <h2 class="accordion-header" id="@headingId">
                <div class="d-flex align-items-center w-100 pe-3">
                    <button class="accordion-button @(isExpanded ? "" : "collapsed") flex-grow-1" type="button"
                            data-bs-toggle="collapse"
                            data-bs-target="#@collapseId"
                            aria-expanded="@(isExpanded.ToString().ToLower())"
                            aria-controls="@collapseId">
                        @pet.Name's Tasks
                        <span class="badge bg-secondary ms-2">@taskCount</span>
                    </button>

                    @* BUG FIX 1: Quick log Pee — hidden localTime field populated client-side to avoid UTC offset *@
                    <form method="post" asp-page-handler="QuickLog"
                          asp-route-petID="@pet.PetID"
                          asp-route-taskType="Pee"
                          asp-route-showAllTime="@Model.ShowAllTime"
                          class="quick-log-form"
                          style="display:inline; margin-left: 6px;">
                        <input type="hidden" name="localTime" />
                        <button type="submit" class="quick-log-btn" title="Quick log Pee">💧</button>
                    </form>

                    @* BUG FIX 1: Quick log Poop — same localTime fix *@
                    <form method="post" asp-page-handler="QuickLog"
                          asp-route-petID="@pet.PetID"
                          asp-route-taskType="Poop"
                          asp-route-showAllTime="@Model.ShowAllTime"
                          class="quick-log-form"
                          style="display:inline; margin-left: 4px;">
                        <input type="hidden" name="localTime" />
                        <button type="submit" class="quick-log-btn" title="Quick log Poop">💩</button>
                    </form>

                    <button type="button" class="btn btn-success btn-sm ms-2 add-task-btn"
                            data-bs-toggle="modal"
                            data-bs-target="#addTaskModal"
                            data-pet-id="@pet.PetID"
                            data-pet-name="@pet.Name">
                        + Add Task
                    </button>
                </div>
            </h2>

            <div id="@collapseId" class="accordion-collapse collapse @(isExpanded ? "show" : "")"
                 aria-labelledby="@headingId">
                <div class="accordion-body p-0">
                    @if (taskCount == 0)
                    {
                        <p class="text-muted fst-italic p-3 mb-0">No tasks logged yet.</p>
                    }
                    else
                    {
                        <table class="table table-sm table-striped mb-0">
                            <thead>
                                <tr>
                                    <th>Task Type</th>
                                    <th>Date & Time</th>
                                    <th>Notes</th>
                                    <th class="task-actions-col d-none">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @{
                                    DateTime? prevTaskDate = null;
                                }
                                @foreach (var task in Model.PetTasks[pet.PetID])
                                {
                                    var isNewDay = prevTaskDate == null || task.CreatedAt.Date != prevTaskDate.Value.Date;
                                    if (isNewDay)
                                    {
                                        <tr class="task-day-separator">
                                            <td colspan="4">@task.CreatedAt.ToString("dddd, MMMM d")</td>
                                        </tr>
                                    }
                                    prevTaskDate = task.CreatedAt.Date;
                                    var timeDisplay = task.CreatedAt.ToString("h:mm tt");
                                    var createdAtInputValue = task.CreatedAt.ToString("yyyy-MM-ddTHH:mm");
                                    <tr>
                                        <td>@HomeModel.TaskTypeEmoji(task.TaskType)</td>
                                        <td>@timeDisplay</td>
                                        <td class="task-notes-cell">@(string.IsNullOrWhiteSpace(task.Notes) ? "-" : task.Notes)</td>
                                        <td class="task-actions-col d-none">
                                            <button class="btn btn-sm btn-edit edit-task-btn"
                                                    data-bs-toggle="modal"
                                                    data-bs-target="#editTaskModal"
                                                    data-task-id="@task.TaskID"
                                                    data-task-type="@task.TaskType"
                                                    data-task-notes="@task.Notes"
                                                    data-task-created="@createdAtInputValue">
                                                Edit
                                            </button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                </div>
            </div>
        </div>
    }
</div>

@* ============================================================
   MODALS
   ============================================================ *@
@section Modals {

    @* ADD PET MODAL *@
    <div class="modal fade" id="addPetModal" tabindex="-1" aria-labelledby="addPetModalLabel" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="addPetModalLabel">Add New Pet</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <form method="post" asp-page-handler="AddPet">
                    <div class="modal-body">
                        <div class="mb-3">
                            <label class="form-label">Name</label>
                            <input asp-for="NewPetName" class="form-control" required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Type</label>
                            <select asp-for="NewPetType" class="form-select" required>
                                <option value="">-- Select --</option>
                                <option>Dog</option>
                                <option>Cat</option>
                                <option>Bird</option>
                                <option>Other</option>
                            </select>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Breed</label>
                            <input asp-for="NewPetBreed" class="form-control" />
                        </div>
                        <div class="row">
                            <div class="col mb-3">
                                <label class="form-label">Age</label>
                                @* BUG FIX 3: id added so JS birthdate→age calc can target this field *@
                                <input asp-for="NewPetAge" class="form-control" id="NewPetAge" placeholder="e.g. 3" />
                            </div>
                            <div class="col mb-3">
                                <label class="form-label">Gender</label>
                                <select asp-for="NewPetGender" class="form-select">
                                    <option value="">-- Select --</option>
                                    <option>Male</option>
                                    <option>Female</option>
                                </select>
                            </div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Birthdate</label>
                            @* BUG FIX 3: id added so change event can fire age calc *@
                            <input asp-for="NewPetBirthdate" type="date" class="form-control" id="NewPetBirthdate" />
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-primary">Add Pet</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    @* EDIT PET MODAL *@
    <div class="modal fade" id="editPetModal" tabindex="-1" aria-labelledby="editPetModalLabel" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="editPetModalLabel">Edit Pet</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>

                <form method="post" asp-page-handler="EditPet" id="editPetForm">
                    <input type="hidden" asp-for="EditPetID" id="editPetID" />
                    <div class="modal-body">
                        <div class="mb-3">
                            <label class="form-label">Name</label>
                            <input asp-for="EditPetName" class="form-control" id="editPetName" required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Type</label>
                            <select asp-for="EditPetType" class="form-select" id="editPetType">
                                <option value="">-- Select --</option>
                                <option>Dog</option>
                                <option>Cat</option>
                                <option>Bird</option>
                                <option>Other</option>
                            </select>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Breed</label>
                            <input asp-for="EditPetBreed" class="form-control" id="editPetBreed" />
                        </div>
                        <div class="row">
                            <div class="col mb-3">
                                <label class="form-label">Age</label>
                                @* BUG FIX 3: id present for birthdate→age calc *@
                                <input asp-for="EditPetAge" class="form-control" id="editPetAge" />
                            </div>
                            <div class="col mb-3">
                                <label class="form-label">Gender</label>
                                <select asp-for="EditPetGender" class="form-select" id="editPetGender">
                                    <option value="">-- Select --</option>
                                    <option>Male</option>
                                    <option>Female</option>
                                </select>
                            </div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Birthdate</label>
                            @* BUG FIX 3: id present for change event *@
                            <input asp-for="EditPetBirthdate" type="date" class="form-control" id="editPetBirthdate" />
                        </div>
                    </div>
                </form>

                <form method="post" asp-page-handler="DeletePet" id="deletePetForm">
                    <input type="hidden" name="EditPetID" id="deletePetID" />
                </form>

                <div class="modal-footer d-flex justify-content-between">
                    <button type="submit" form="deletePetForm" class="btn btn-danger"
                            onclick="return confirm('Are you sure you want to delete this pet? This will also delete all their tasks.');">
                        Delete Pet
                    </button>
                    <div>
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" form="editPetForm" class="btn btn-warning">Save Changes</button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @* ADD TASK MODAL *@
    <div class="modal fade" id="addTaskModal" tabindex="-1" aria-labelledby="addTaskModalLabel" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="addTaskModalLabel">
                        Add Task for <span id="addTaskPetName"></span>
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <form method="post" asp-page-handler="AddTask">
                    <input type="hidden" name="NewTaskPetID" id="newTaskPetID" />
                    <div class="modal-body">
                        <div class="mb-3">
                            <label class="form-label">Task Type</label>
                            <select name="NewTaskType" class="form-select" required>
                                <option value="">-- Select --</option>
                                <option>Pee</option>
                                <option>Poop</option>
                                <option>Pee & Poop</option>
                                <option>Food</option>
                                <option>Water</option>
                                <option>Walk</option>
                                <option>Other</option>
                            </select>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Date & Time</label>
                            <input type="datetime-local" name="NewTaskCreatedAt" id="newTaskCreatedAt"
                                   class="form-control" required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Notes</label>
                            <textarea name="NewTaskNotes" class="form-control" rows="3"
                                      placeholder="Optional notes..."></textarea>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-success">Add Task</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    @* EDIT TASK MODAL *@
    <div class="modal fade" id="editTaskModal" tabindex="-1" aria-labelledby="editTaskModalLabel" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="editTaskModalLabel">Edit Task</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <form method="post" asp-page-handler="UpdateTask" id="editTaskForm">
                    <input type="hidden" name="UpdateTaskID" id="editTaskID" />
                    <input type="hidden" name="ShowAllTime" value="@Model.ShowAllTime.ToString().ToLower()" />
                    <div class="modal-body">
                        <div class="mb-3">
                            <label class="form-label">Task Type</label>
                            <select name="UpdateTaskType" id="editTaskType" class="form-select" required>
                                <option value="">-- Select --</option>
                                <option>Pee</option>
                                <option>Poop</option>
                                <option>Pee & Poop</option>
                                <option>Food</option>
                                <option>Water</option>
                                <option>Walk</option>
                                <option>Other</option>
                            </select>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Date & Time</label>
                            <input type="datetime-local" name="UpdateTaskCreatedAt" id="editTaskCreatedAt"
                                   class="form-control" required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Notes</label>
                            <textarea name="UpdateTaskNotes" id="editTaskNotes" class="form-control" rows="3"
                                      placeholder="Optional notes..."></textarea>
                        </div>
                    </div>
                </form>
                <form method="post" asp-page-handler="DeleteTask" id="deleteTaskForm">
                    <input type="hidden" name="taskID" id="deleteTaskID" />
                    <input type="hidden" name="ShowAllTime" value="@Model.ShowAllTime.ToString().ToLower()" />
                </form>
                <div class="modal-footer d-flex justify-content-between">
                    <button type="submit" form="deleteTaskForm" class="btn btn-danger"
                            onclick="return confirm('Delete this task?');">
                        Delete Task
                    </button>
                    <div>
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" form="editTaskForm" class="btn btn-success">Update Task</button>
                    </div>
                </div>
            </div>
        </div>
    </div>

} @* end @section Modals *@

@section Scripts {
    <script>
        // Pet actions hidden by default; Edit Pets toggles visibility.
        const togglePetActionsBtn = document.getElementById('togglePetActionsBtn');
        const petActionCells = document.querySelectorAll('.pet-actions-col');

        if (togglePetActionsBtn) {
            togglePetActionsBtn.addEventListener('click', function () {
                const isActive = this.classList.toggle('active');
                this.setAttribute('aria-pressed', isActive ? 'true' : 'false');
                petActionCells.forEach(cell => cell.classList.toggle('d-none', !isActive));
                // Solid red on edit buttons when mode is active
                document.querySelectorAll('.edit-pet-btn').forEach(btn => btn.classList.toggle('active', isActive));
            });
        }

        // Task actions hidden by default; Edit Tasks toggles visibility.
        const toggleTaskActionsBtn = document.getElementById('toggleTaskActionsBtn');
        const taskActionCells = document.querySelectorAll('.task-actions-col');

        if (toggleTaskActionsBtn) {
            toggleTaskActionsBtn.addEventListener('click', function () {
                const isActive = this.classList.toggle('active');
                this.setAttribute('aria-pressed', isActive ? 'true' : 'false');
                taskActionCells.forEach(cell => cell.classList.toggle('d-none', !isActive));
                // Solid red on edit buttons when mode is active
                document.querySelectorAll('.edit-task-btn').forEach(btn => btn.classList.toggle('active', isActive));
            });
        }

        // BUG FIX 1: Quick log — inject client local time before submit to avoid UTC offset
        document.querySelectorAll('.quick-log-form').forEach(form => {
            form.addEventListener('submit', function () {
                const now = new Date();
                const local = now.getFullYear() + '-' +
                    String(now.getMonth() + 1).padStart(2, '0') + '-' +
                    String(now.getDate()).padStart(2, '0') + 'T' +
                    String(now.getHours()).padStart(2, '0') + ':' +
                    String(now.getMinutes()).padStart(2, '0') + ':' +
                    String(now.getSeconds()).padStart(2, '0');
                this.querySelector('input[name="localTime"]').value = local;
            });
        });

        // BUG FIX 3: Birthdate → Age auto-calc
        function calcAge(birthdateValue) {
            if (!birthdateValue) return '';
            const birth = new Date(birthdateValue);
            const today = new Date();
            let age = today.getFullYear() - birth.getFullYear();
            const m = today.getMonth() - birth.getMonth();
            if (m < 0 || (m === 0 && today.getDate() < birth.getDate())) age--;
            return age >= 0 ? String(age) : '';
        }

        document.getElementById('NewPetBirthdate').addEventListener('change', function () {
            document.getElementById('NewPetAge').value = calcAge(this.value);
        });

        document.getElementById('editPetBirthdate').addEventListener('change', function () {
            document.getElementById('editPetAge').value = calcAge(this.value);
        });

        // Edit Pet modal — populate fields from data attributes
        document.querySelectorAll('.edit-pet-btn').forEach(button => {
            button.addEventListener('click', function () {
                document.getElementById('editPetID').value        = this.dataset.petId;
                document.getElementById('deletePetID').value      = this.dataset.petId;
                document.getElementById('editPetName').value      = this.dataset.petName;
                document.getElementById('editPetType').value      = this.dataset.petType;
                document.getElementById('editPetBreed').value     = this.dataset.petBreed;
                document.getElementById('editPetAge').value       = this.dataset.petAge;
                document.getElementById('editPetBirthdate').value = this.dataset.petBirthdate;
                document.getElementById('editPetGender').value    = this.dataset.petGender;
            });
        });

        // Edit Task modal — populate fields from data attributes
        document.querySelectorAll('.edit-task-btn').forEach(button => {
            button.addEventListener('click', function () {
                document.getElementById('editTaskID').value           = this.dataset.taskId;
                document.getElementById('editTaskType').value         = this.dataset.taskType;
                document.getElementById('editTaskNotes').value        = this.dataset.taskNotes || '';
                document.getElementById('editTaskCreatedAt').value    = this.dataset.taskCreated;
                document.getElementById('deleteTaskID').value         = this.dataset.taskId;
            });
        });

        // Add Task modal — populate pet ID/name and default datetime to now
        document.querySelectorAll('.add-task-btn').forEach(button => {
            button.addEventListener('click', function () {
                document.getElementById('newTaskPetID').value         = this.dataset.petId;
                document.getElementById('addTaskPetName').textContent = this.dataset.petName;

                const now = new Date();
                const formatted = now.getFullYear() + '-' +
                    String(now.getMonth() + 1).padStart(2, '0') + '-' +
                    String(now.getDate()).padStart(2, '0') + 'T' +
                    String(now.getHours()).padStart(2, '0') + ':' +
                    String(now.getMinutes()).padStart(2, '0');
                document.getElementById('newTaskCreatedAt').value = formatted;
            });
        });
    </script>
}
