@page
@model PetPotty.Pages.HomeModel
@{
    ViewData["Title"] = "Home";
}

@if (TempData["StatusMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["StatusMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<h1>Pet Dashboard</h1>

<style>
    /* ── Pet card grid ── */
    .pet-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
        gap: 1.25rem;
        margin-bottom: 2rem;
    }

    .pet-card {
        position: relative;
        background: rgba(255, 255, 255, 0.72);
        backdrop-filter: blur(14px);
        -webkit-backdrop-filter: blur(14px);
        border: 1px solid rgba(255, 255, 255, 0.5);
        box-shadow: 0 4px 24px rgba(139, 69, 19, 0.08);
        border-radius: 20px;
        padding: 1.5rem;
        transition: transform 0.22s cubic-bezier(.16,1,.3,1),
                    box-shadow 0.22s cubic-bezier(.16,1,.3,1);
    }

    .pet-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 12px 36px rgba(139, 69, 19, 0.15);
    }

    .pet-icon-Dog   { background: #fef3c7; }
    .pet-icon-Cat   { background: #dbeafe; }
    .pet-icon-Bird  { background: #d1fae5; }
    .pet-icon-Other { background: #ede9fe; }

    .pet-icon {
        width: 56px;
        height: 56px;
        border-radius: 16px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.75rem;
        flex-shrink: 0;
    }

    .breed-badge {
        display: inline-block;
        padding: 2px 10px;
        border-radius: 6px;
        font-size: 0.7rem;
        font-weight: 700;
        letter-spacing: 0.05em;
        text-transform: uppercase;
        background: rgba(139, 69, 19, 0.1);
        color: var(--pet-primary);
        margin-top: 2px;
    }

    .pet-info-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 0.5rem;
        margin: 1rem 0;
    }

    .pet-info-item {
        background: rgba(245, 222, 179, 0.3);
        border-radius: 10px;
        padding: 0.5rem 0.75rem;
    }

    .pet-info-label {
        font-size: 0.68rem;
        color: #9ca3af;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }

    .pet-info-value {
        font-size: 0.9rem;
        font-weight: 600;
        color: var(--pet-dark);
    }

    .pet-edit-overlay {
        position: absolute;
        top: 14px;
        right: 14px;
        opacity: 0;
        transform: scale(0.85);
        transition: opacity 0.18s ease, transform 0.18s ease;
    }

    .pet-card:hover .pet-edit-overlay,
    .edit-mode-on .pet-edit-overlay {
        opacity: 1;
        transform: scale(1);
    }

    .pet-edit-btn {
        width: 34px;
        height: 34px;
        border-radius: 50%;
        border: none;
        background: white;
        box-shadow: 0 2px 8px rgba(0,0,0,0.12);
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        color: var(--pet-primary);
        transition: background 0.15s ease;
    }

    .pet-edit-btn:hover { background: var(--pet-neutral); }

    .edit-pets-toggle {
        border: 2px solid #198754;
        color: #198754;
        background-color: transparent;
        transition: background-color 0.2s ease, border-color 0.2s ease, color 0.2s ease;
    }
    .edit-pets-toggle:hover { background-color: #198754; border-color: #198754; color: #fff; }
    .edit-pets-toggle.active { background-color: #198754; border-color: #198754; color: #fff; }
    .edit-pets-toggle.active:hover { background-color: #dc3545; border-color: #dc3545; color: #fff; }

    /* ── Task card grid ── */
    .task-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
        gap: 0.75rem;
        padding: 1rem;
    }

    .task-card {
        position: relative;
        background: white;
        border-radius: 14px;
        padding: 0.9rem 1rem;
        border: 1px solid rgba(244, 164, 96, 0.3);
        box-shadow: 0 2px 8px rgba(139, 69, 19, 0.06);
        display: flex;
        align-items: flex-start;
        gap: 0.75rem;
        transition: box-shadow 0.18s ease, transform 0.18s ease;
    }

    .task-card:hover {
        box-shadow: 0 4px 16px rgba(139, 69, 19, 0.12);
        transform: translateY(-2px);
    }

    .task-emoji {
        font-size: 1.5rem;
        flex-shrink: 0;
        line-height: 1;
        margin-top: 2px;
    }

    .task-type {
        font-weight: 700;
        font-size: 0.9rem;
        color: var(--pet-dark);
        line-height: 1.2;
    }

    .task-time {
        font-size: 0.72rem;
        color: #9ca3af;
        margin-top: 2px;
    }

    .task-notes {
        font-size: 0.78rem;
        color: #6b7280;
        margin-top: 4px;
        word-break: break-word;
    }

    /* Edit button on task card — appears on hover */
    .task-edit-overlay {
        position: absolute;
        top: 8px;
        right: 8px;
        opacity: 0;
        transition: opacity 0.15s ease;
    }

    .task-card:hover .task-edit-overlay {
        opacity: 1;
    }

    .task-edit-btn {
        width: 26px;
        height: 26px;
        border-radius: 50%;
        border: none;
        background: rgba(255,255,255,0.9);
        box-shadow: 0 1px 4px rgba(0,0,0,0.15);
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        color: var(--pet-primary);
        font-size: 0.7rem;
        transition: background 0.12s ease;
    }

    .task-edit-btn:hover { background: var(--pet-neutral); }

    /* ── Quick log buttons ── */
    .quick-log-btn {
        width: 36px;
        height: 36px;
        border-radius: 10px;
        border: 1px solid rgba(244, 164, 96, 0.4);
        background: white;
        font-size: 1.1rem;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: background 0.15s ease, transform 0.1s ease, border-color 0.15s ease;
        padding: 0;
        line-height: 1;
    }

    .quick-log-btn:hover {
        background: rgba(244, 164, 96, 0.15);
        border-color: var(--pet-secondary);
        transform: scale(1.1);
    }

    .quick-log-btn:active { transform: scale(0.95); }

    /* ── No tasks placeholder ── */
    .no-tasks {
        padding: 1.5rem;
        text-align: center;
        color: #9ca3af;
        font-style: italic;
        font-size: 0.9rem;
    }
</style>

@* ============================================================
   PETS SECTION — glass card grid
   ============================================================ *@
<div class="d-flex align-items-center justify-content-between mb-3">
    <h2 class="mb-0">My Pets 🐾</h2>
    <div class="d-flex align-items-center gap-2">
        <button hidden="true" type="button" class="btn btn-sm edit-pets-toggle" id="toggleEditMode" aria-pressed="false">
            Edit Pets
        </button>
        <button type="button" class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#addPetModal">
            + Add Pet
        </button>
    </div>
</div>

<div class="pet-grid" id="petGrid">
    @if (!Model.Pets.Any())
    {
        <p class="text-muted" style="grid-column: 1 / -1;">absolutely No pets on this account. <a href="#" data-bs-toggle="modal" data-bs-target="#addPetModal">Add one now</a></p>
    }
    @foreach (var pet in Model.Pets)
    {
        var petBirthdate = pet.Birthdate.ToString("yyyy-MM-dd");
        var petEmoji = pet.Type switch {
            "Dog"  => "🐕",
            "Cat"  => "🐈",
            "Bird" => "🐦",
            _      => "🐾"
        };
        var collapseId = $"collapse-{pet.PetID}";

        <div class="pet-card">
            <div class="pet-edit-overlay">
                <button class="pet-edit-btn edit-pet-btn"
                        data-bs-toggle="modal"
                        data-bs-target="#editPetModal"
                        data-pet-id="@pet.PetID"
                        data-pet-name="@pet.Name"
                        data-pet-type="@pet.Type"
                        data-pet-breed="@pet.Breed"
                        data-pet-age="@pet.Age"
                        data-pet-birthdate="@petBirthdate"
                        data-pet-gender="@pet.Gender"
                        title="Edit @pet.Name">
                    <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" fill="none"
                         viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round"
                              d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z" />
                    </svg>
                </button>
            </div>

            <div class="d-flex align-items-center gap-3 mb-3">
                <div class="pet-icon pet-icon-@pet.Type">@petEmoji</div>
                <div>
                    <div class="fw-bold fs-5" style="line-height:1.1;">@pet.Name</div>
                    <span class="breed-badge">@(string.IsNullOrWhiteSpace(pet.Breed) ? pet.Type : pet.Breed)</span>
                </div>
            </div>

            <div class="pet-info-grid">
                <div class="pet-info-item">
                    <div class="pet-info-label">Type</div>
                    <div class="pet-info-value">@pet.Type</div>
                </div>
                <div class="pet-info-item">
                    <div class="pet-info-label">Age</div>
                    <div class="pet-info-value">@pet.Age yrs</div>
                </div>
                <div class="pet-info-item">
                    <div class="pet-info-label">Gender</div>
                    <div class="pet-info-value">@(string.IsNullOrWhiteSpace(pet.Gender) ? "-" : pet.Gender)</div>
                </div>
                <div class="pet-info-item">
                    <div class="pet-info-label">Birthday</div>
                    <div class="pet-info-value">@pet.Birthdate.ToString("MM/dd/yy")</div>
                </div>
            </div>

            <button class="view-tasks-btn w-100 btn btn-sm"
                    style="border: 1px solid rgba(139,69,19,0.2); background: white; border-radius: 12px; padding: 0.5rem; font-weight: 600; font-size: 0.85rem;"
                    onclick="scrollToTasks('@collapseId')">
                View Tasks ↓
            </button>
        </div>
    }
</div>

@* ============================================================
   TASKS SECTION
   ============================================================ *@
<div class="d-flex align-items-center justify-content-between mb-3">
    <div class="d-flex align-items-center gap-3">
        <h2 class="mb-0">Tasks</h2>
        <a href="/Home?showAllTime=@(!Model.ShowAllTime)" class="btn btn-link p-0">
            @(Model.ShowAllTime ? "Show Past 24 Hours" : "Show All Time")
        </a>
        <span class="text-muted">(@(Model.ShowAllTime ? "All Time" : "Past 24 Hours"))</span>
    </div>
</div>

<div class="accordion" id="tasksAccordion">
    @if (!Model.Pets.Any())
    {
        <p class="text-muted">No pets on this account. <a href="#" data-bs-toggle="modal" data-bs-target="#addPetModal">Add one now</a></p>
    }
    @foreach (var pet in Model.Pets)
    {
        var taskCount  = Model.PetTasks[pet.PetID].Count;
        var collapseId = $"collapse-{pet.PetID}";
        var headingId  = $"heading-{pet.PetID}";

        <div class="accordion-item mb-2">
            <h2 class="accordion-header" id="@headingId">
                <div class="d-flex align-items-center w-100 pe-3">
                    <button class="accordion-button flex-grow-1" type="button"
                            data-bs-toggle="collapse"
                            data-bs-target="#@collapseId"
                            aria-expanded="false"
                            aria-controls="@collapseId">
                        @pet.Name's Tasks
                        <span class="badge bg-secondary ms-2">@taskCount</span>
                    </button>

                    @* Quick log — Pee *@
                    <form method="post" asp-page-handler="QuickLog"
                          asp-route-petID="@pet.PetID"
                          asp-route-taskType="Pee"
                          asp-route-showAllTime="@Model.ShowAllTime"
                          style="display:inline; margin-left: 6px;">
                        <button type="submit" class="quick-log-btn" title="Quick log Pee">💧</button>
                    </form>

                    @* Quick log — Poop *@
                    <form method="post" asp-page-handler="QuickLog"
                          asp-route-petID="@pet.PetID"
                          asp-route-taskType="Poop"
                          asp-route-showAllTime="@Model.ShowAllTime"
                          style="display:inline; margin-left: 4px;">
                        <button type="submit" class="quick-log-btn" title="Quick log Poop">💩</button>
                    </form>

                    @* Add Task modal button *@
                    <button type="button"
                            class="quick-log-btn add-task-btn ms-1"
                            data-bs-toggle="modal"
                            data-bs-target="#addTaskModal"
                            data-pet-id="@pet.PetID"
                            data-pet-name="@pet.Name"
                            title="Add task"
                            style="font-size: 1.2rem; font-weight: bold;">
                        +
                    </button>
                </div>
            </h2>

            <div id="@collapseId" class="accordion-collapse collapse"
                 aria-labelledby="@headingId">
                <div class="accordion-body p-0">
                    @if (taskCount == 0)
                    {
                        <div class="no-tasks">No tasks logged yet.</div>
                    }
                    else
                    {
                        <div class="task-grid">
                            @foreach (var task in Model.PetTasks[pet.PetID])
                            {
                                var taskEmoji = task.TaskType switch {
                                    "Pee"        => "💧",
                                    "Poop"       => "💩",
                                    "Pee & Poop" => "✨",
                                    "Food"       => "🍽️",
                                    "Water"      => "💦",
                                    "Walk"       => "🚶",
                                    _            => "📝"
                                };
                                var createdAtInput = task.CreatedAt.ToString("yyyy-MM-ddTHH:mm");

                                <div class="task-card">
                                    @* Edit button — appears on hover *@
                                    <div class="task-edit-overlay">
                                        <button class="task-edit-btn edit-task-btn"
                                                data-bs-toggle="modal"
                                                data-bs-target="#editTaskModal"
                                                data-task-id="@task.TaskID"
                                                data-task-type="@task.TaskType"
                                                data-task-notes="@task.Notes"
                                                data-task-created="@createdAtInput"
                                                title="Edit task">
                                            ✏️
                                        </button>
                                    </div>

                                    <div class="task-emoji">@taskEmoji</div>
                                    <div class="flex-grow-1" style="min-width:0;">
                                        <div class="task-type">@task.TaskType</div>
                                        <div class="task-time">@task.CreatedAt.ToString("MM/dd/yy h:mm tt")</div>
                                        @if (!string.IsNullOrWhiteSpace(task.Notes))
                                        {
                                            <div class="task-notes">@task.Notes</div>
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
    }
</div>

@* ============================================================
   MODALS
   ============================================================ *@
@section Modals {

    @* ADD PET MODAL *@
    <div class="modal fade" id="addPetModal" tabindex="-1" aria-labelledby="addPetModalLabel" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="addPetModalLabel">Add New Pet</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <form method="post" asp-page-handler="AddPet">
                    <div class="modal-body">
                        <div class="mb-3">
                            <label class="form-label">Name</label>
                            <input asp-for="NewPetName" class="form-control" required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Type</label>
                            <select asp-for="NewPetType" class="form-select" required>
                                <option value="">-- Select --</option>
                                <option>Dog</option>
                                <option>Cat</option>
                                <option>Bird</option>
                                <option>Other</option>
                            </select>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Breed</label>
                            <input asp-for="NewPetBreed" class="form-control" />
                        </div>
                        <div class="row">
                            <div class="col mb-3">
                                <label class="form-label">Age</label>
                                <input asp-for="NewPetAge" class="form-control" placeholder="e.g. 3" />
                            </div>
                            <div class="col mb-3">
                                <label class="form-label">Gender</label>
                                <select asp-for="NewPetGender" class="form-select">
                                    <option value="">-- Select --</option>
                                    <option>Male</option>
                                    <option>Female</option>
                                </select>
                            </div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Birthdate</label>
                            <input asp-for="NewPetBirthdate" type="date" class="form-control" />
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-primary">Add Pet</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    @* EDIT PET MODAL *@
    <div class="modal fade" id="editPetModal" tabindex="-1" aria-labelledby="editPetModalLabel" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="editPetModalLabel">Edit Pet</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <form method="post" asp-page-handler="EditPet" id="editPetForm">
                    <input type="hidden" asp-for="EditPetID" id="editPetID" />
                    <div class="modal-body">
                        <div class="mb-3">
                            <label class="form-label">Name</label>
                            <input asp-for="EditPetName" class="form-control" id="editPetName" required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Type</label>
                            <select asp-for="EditPetType" class="form-select" id="editPetType">
                                <option value="">-- Select --</option>
                                <option>Dog</option>
                                <option>Cat</option>
                                <option>Bird</option>
                                <option>Other</option>
                            </select>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Breed</label>
                            <input asp-for="EditPetBreed" class="form-control" id="editPetBreed" />
                        </div>
                        <div class="row">
                            <div class="col mb-3">
                                <label class="form-label">Age</label>
                                <input asp-for="EditPetAge" class="form-control" id="editPetAge" />
                            </div>
                            <div class="col mb-3">
                                <label class="form-label">Gender</label>
                                <select asp-for="EditPetGender" class="form-select" id="editPetGender">
                                    <option value="">-- Select --</option>
                                    <option>Male</option>
                                    <option>Female</option>
                                </select>
                            </div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Birthdate</label>
                            <input asp-for="EditPetBirthdate" type="date" class="form-control" id="editPetBirthdate" />
                        </div>
                    </div>
                </form>
                <form method="post" asp-page-handler="DeletePet" id="deletePetForm">
                    <input type="hidden" name="EditPetID" id="deletePetID" />
                </form>
                <div class="modal-footer d-flex justify-content-between">
                    <button type="submit" form="deletePetForm" class="btn btn-danger"
                            onclick="return confirm('Delete this pet and all their tasks?');">
                        Delete Pet
                    </button>
                    <div>
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" form="editPetForm" class="btn btn-warning">Save Changes</button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @* ADD TASK MODAL *@
    <div class="modal fade" id="addTaskModal" tabindex="-1" aria-labelledby="addTaskModalLabel" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="addTaskModalLabel">
                        Add Task for <span id="addTaskPetName"></span>
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <form method="post" asp-page-handler="AddTask">
                    <input type="hidden" name="NewTaskPetID" id="newTaskPetID" />
                    <div class="modal-body">
                        <div class="mb-3">
                            <label class="form-label">Task Type</label>
                            <select name="NewTaskType" class="form-select" required>
                                <option value="">-- Select --</option>
                                <option>Pee</option>
                                <option>Poop</option>
                                <option>Pee & Poop</option>
                                <option>Food</option>
                                <option>Water</option>
                                <option>Walk</option>
                                <option>Other</option>
                            </select>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Date & Time</label>
                            <input type="datetime-local" name="NewTaskCreatedAt" id="newTaskCreatedAt"
                                   class="form-control" required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Notes</label>
                            <textarea name="NewTaskNotes" class="form-control" rows="3"
                                      placeholder="Optional notes..."></textarea>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-success">Add Task</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    @* EDIT TASK MODAL *@
    <div class="modal fade" id="editTaskModal" tabindex="-1" aria-labelledby="editTaskModalLabel" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="editTaskModalLabel">Edit Task</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <form method="post" asp-page-handler="UpdateTask" id="editTaskForm">
                    <input type="hidden" name="UpdateTaskID" id="editTaskID" />
                    <input type="hidden" name="ShowAllTime" value="@Model.ShowAllTime.ToString().ToLower()" />
                    <div class="modal-body">
                        <div class="mb-3">
                            <label class="form-label">Task Type</label>
                            <select name="UpdateTaskType" id="editTaskType" class="form-select" required>
                                <option value="">-- Select --</option>
                                <option>Pee</option>
                                <option>Poop</option>
                                <option>Pee & Poop</option>
                                <option>Food</option>
                                <option>Water</option>
                                <option>Walk</option>
                                <option>Other</option>
                            </select>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Date & Time</label>
                            <input type="datetime-local" name="UpdateTaskCreatedAt" id="editTaskCreatedAt"
                                   class="form-control" required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Notes</label>
                            <textarea name="UpdateTaskNotes" id="editTaskNotes" class="form-control" rows="3"
                                      placeholder="Optional notes..."></textarea>
                        </div>
                    </div>
                </form>
                <form method="post" asp-page-handler="DeleteTask" id="deleteTaskForm">
                    <input type="hidden" name="taskID" id="deleteTaskID" />
                    <input type="hidden" name="ShowAllTime" value="@Model.ShowAllTime.ToString().ToLower()" />
                </form>
                <div class="modal-footer d-flex justify-content-between">
                    <button type="submit" form="deleteTaskForm" class="btn btn-danger"
                            onclick="return confirm('Delete this task?');">
                        Delete Task
                    </button>
                    <div>
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" form="editTaskForm" class="btn btn-success">Update Task</button>
                    </div>
                </div>
            </div>
        </div>
    </div>

} @* end @section Modals *@

@section Scripts {
    <script>
        // ── Accordion state — persist in localStorage, default first 2 open ──
        const STORAGE_KEY = 'petAccordionState';

        function getAccordionState() {
            try { return JSON.parse(localStorage.getItem(STORAGE_KEY)); }
            catch { return null; }
        }

        function saveAccordionState() {
            const state = {};
            document.querySelectorAll('.accordion-collapse').forEach(el => {
                state[el.id] = el.classList.contains('show');
            });
            localStorage.setItem(STORAGE_KEY, JSON.stringify(state));
        }

        function applyAccordionState() {
            const state = getAccordionState();
            document.querySelectorAll('.accordion-collapse').forEach((el, index) => {
                const btn = document.querySelector(`[data-bs-target="#${el.id}"]`);
                const shouldOpen = state !== null ? state[el.id] === true : index < 2;
                el.classList.toggle('show', shouldOpen);
                if (btn) {
                    btn.classList.toggle('collapsed', !shouldOpen);
                    btn.setAttribute('aria-expanded', shouldOpen ? 'true' : 'false');
                }
            });
        }

        applyAccordionState();

        document.querySelectorAll('.accordion-collapse').forEach(el => {
            el.addEventListener('shown.bs.collapse', saveAccordionState);
            el.addEventListener('hidden.bs.collapse', saveAccordionState);
        });

        // ── Scroll to pet's task accordion ──
        function scrollToTasks(collapseId) {
            const collapseEl = document.getElementById(collapseId);
            if (!collapseEl) return;
            if (!collapseEl.classList.contains('show')) {
                new bootstrap.Collapse(collapseEl, { toggle: false }).show();
            }
            const item = collapseEl.closest('.accordion-item');
            if (item) {
                setTimeout(() => {
                    item.scrollIntoView({ behavior: 'smooth', block: 'start' });
                    item.style.transition = 'box-shadow 0.3s ease';
                    item.style.boxShadow = '0 0 0 3px rgba(244, 164, 96, 0.5)';
                    setTimeout(() => item.style.boxShadow = '', 1800);
                }, 150);
            }
        }

        // ── Edit Pets mode — shows pencil on all cards ──
        const toggleEditBtn = document.getElementById('toggleEditMode');
        const petGrid = document.getElementById('petGrid');

        if (toggleEditBtn) {
            toggleEditBtn.addEventListener('click', function () {
                const isActive = this.classList.toggle('active');
                this.setAttribute('aria-pressed', isActive ? 'true' : 'false');
                petGrid.classList.toggle('edit-mode-on', isActive);
            });
        }

        // ── Edit Pet modal ──
        document.querySelectorAll('.edit-pet-btn').forEach(button => {
            button.addEventListener('click', function () {
                document.getElementById('editPetID').value        = this.dataset.petId;
                document.getElementById('deletePetID').value      = this.dataset.petId;
                document.getElementById('editPetName').value      = this.dataset.petName;
                document.getElementById('editPetType').value      = this.dataset.petType;
                document.getElementById('editPetBreed').value     = this.dataset.petBreed;
                document.getElementById('editPetAge').value       = this.dataset.petAge;
                document.getElementById('editPetBirthdate').value = this.dataset.petBirthdate;
                document.getElementById('editPetGender').value    = this.dataset.petGender;
            });
        });

        // ── Edit Task modal ──
        document.querySelectorAll('.edit-task-btn').forEach(button => {
            button.addEventListener('click', function () {
                document.getElementById('editTaskID').value         = this.dataset.taskId;
                document.getElementById('editTaskType').value       = this.dataset.taskType;
                document.getElementById('editTaskNotes').value      = this.dataset.taskNotes || '';
                document.getElementById('editTaskCreatedAt').value  = this.dataset.taskCreated;
                document.getElementById('deleteTaskID').value       = this.dataset.taskId;
            });
        });

        // ── Add Task modal — set pet and default time ──
        document.querySelectorAll('.add-task-btn').forEach(button => {
            button.addEventListener('click', function () {
                document.getElementById('newTaskPetID').value         = this.dataset.petId;
                document.getElementById('addTaskPetName').textContent = this.dataset.petName;

                const now = new Date();
                const formatted = now.getFullYear() + '-' +
                    String(now.getMonth() + 1).padStart(2, '0') + '-' +
                    String(now.getDate()).padStart(2, '0') + 'T' +
                    String(now.getHours()).padStart(2, '0') + ':' +
                    String(now.getMinutes()).padStart(2, '0');
                document.getElementById('newTaskCreatedAt').value = formatted;
            });
        });
    </script>
}
