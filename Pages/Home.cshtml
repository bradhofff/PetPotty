@page
@model PetPotty.Pages.HomeModel
@{
    ViewData["Title"] = "Dashboard";
}

<style>
    /* ── Welcome header ── */
    .home-welcome h1 {
        font-size: 2rem;
        font-weight: 800;
        color: var(--pet-dark);
        margin-bottom: 2px;
    }
    .home-welcome p {
        color: #888;
        font-size: 1rem;
        margin: 0;
    }

    /* ── Pet cards ── */
    .pet-card {
        border: 2px solid var(--pet-secondary);
        border-radius: 16px;
        background: white;
        padding: 18px;
        position: relative;
        box-shadow: 0 2px 10px rgba(139,69,19,0.07);
        transition: box-shadow 0.2s ease;
    }
    .pet-card:hover {
        box-shadow: 0 5px 18px rgba(139,69,19,0.14);
    }

    /* Pencil icon — hidden until hover */
    .pet-card-edit-btn {
        position: absolute;
        top: 12px; right: 12px;
        width: 32px; height: 32px;
        border-radius: 50%;
        border: 2px solid #fd7e14;
        color: #fd7e14;
        background: white;
        display: flex; align-items: center; justify-content: center;
        font-size: 0.82rem;
        opacity: 0;
        transition: opacity 0.18s ease, background 0.18s ease;
        cursor: pointer;
        padding: 0;
        line-height: 1;
    }
    .pet-card:hover .pet-card-edit-btn { opacity: 1; }
    .pet-card-edit-btn:hover {
        background: #fd7e14;
        color: white;
    }

    /* Avatar circle */
    .pet-avatar {
        width: 52px; height: 52px;
        border-radius: 50%;
        background: rgba(244,164,96,0.22);
        display: flex; align-items: center; justify-content: center;
        font-size: 1.7rem;
        flex-shrink: 0;
        overflow: hidden;
    }
    .pet-avatar img {
        width: 52px; height: 52px;
        object-fit: cover;
        display: block;
    }
    .pet-image-preview {
        width: 88px; height: 88px;
        border-radius: 50%;
        background: rgba(244,164,96,0.22);
        display: flex; align-items: center; justify-content: center;
        font-size: 2.4rem;
        overflow: hidden;
        margin: 0 auto 12px;
    }
    .pet-image-preview img {
        width: 88px; height: 88px;
        object-fit: cover;
        display: none;
    }

    /* Quick-log pill buttons */
    .quick-log-pill {
        border: 2px solid var(--pet-secondary);
        border-radius: 999px;
        background: white;
        color: var(--pet-dark);
        padding: 6px 18px;
        font-size: 0.88rem;
        font-weight: 500;
        cursor: pointer;
        transition: background 0.15s ease, transform 0.1s ease;
        line-height: 1.2;
    }
    .quick-log-form {
        align-items: center;
        display: flex;
        flex-direction: column;
        min-width: 0;
    }
    .quick-log-icon {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 1.25em;
        height: 1.25em;
        margin-right: 4px;
        font-size: 1rem;
        line-height: 1;
        vertical-align: -0.12em;
    }
    .quick-log-pill:hover {
        background: rgba(244,164,96,0.18);
        transform: scale(1.04);
    }
    .quick-log-pill:active { transform: scale(0.96); }
    .quick-log-label {
        color: #111;
        font-size: 0.8rem;
        font-weight: 400;
        line-height: 1.2;
        margin-bottom: 5px;
        max-width: 220px;
        text-align: center;
        width: max-content;
    }

    /* Add Task button inside card */
    .add-task-card-btn {
        width: 100%;
        border-radius: 999px;
        background: var(--pet-primary);
        color: white;
        border: none;
        padding: 9px 0;
        font-size: 0.92rem;
        font-weight: 600;
        cursor: pointer;
        transition: background 0.2s ease, transform 0.1s ease;
    }
    .add-task-card-btn:hover {
        background: #6b3410;
        transform: translateY(-1px);
    }
    .add-task-card-btn:active { transform: translateY(0); }

    /* ── Task log cards ── */
    .task-log-card {
        border: 2px solid rgba(244,164,96,0.45);
        border-radius: 16px;
        background: white;
        box-shadow: 0 2px 8px rgba(139,69,19,0.06);
        overflow: hidden;
    }
    .task-log-card-header {
        border-bottom: 1px solid rgba(244,164,96,0.3);
    }
    .task-log-toggle {
        width: 100%;
        border: 0;
        background: transparent;
        color: var(--pet-dark);
        padding: 14px 18px 10px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        font-weight: 700;
        font-size: 1rem;
        text-align: left;
        cursor: pointer;
    }
    .task-log-toggle:hover {
        background: rgba(244,164,96,0.12);
    }
    .task-log-caret {
        color: var(--pet-primary);
        font-size: 0.95rem;
        line-height: 1;
        transition: transform 0.18s ease;
        flex-shrink: 0;
    }
    .task-log-toggle.collapsed .task-log-caret {
        transform: rotate(180deg);
    }
    .task-log-card-body {
        padding: 0 18px 14px;
    }

    /* Date pill separator */
    .task-date-pill {
        display: inline-block;
        background: rgba(244,164,96,0.18);
        color: var(--pet-primary);
        border: 1px solid rgba(244,164,96,0.45);
        border-radius: 999px;
        font-size: 0.75rem;
        font-weight: 700;
        padding: 3px 12px;
        margin: 12px 0 6px;
        text-transform: uppercase;
        letter-spacing: 0.04em;
    }

    /* Individual task row */
    .task-row {
        display: flex;
        align-items: flex-start;
        gap: 10px;
        padding: 7px 0;
        border-bottom: 1px solid rgba(244,164,96,0.18);
    }
    .task-row:last-child { border-bottom: none; }

    /* Task icon circle */
    .task-icon {
        width: 34px; height: 34px;
        border-radius: 50%;
        background: rgba(244,164,96,0.15);
        display: flex; align-items: center; justify-content: center;
        font-size: 1rem;
        flex-shrink: 0;
        margin-top: 1px;
    }

    /* Edit task button (hidden until Edit Tasks toggle) */
    .edit-task-btn {
        font-size: 0.75rem;
        padding: 2px 8px;
        border-radius: 12px;
        line-height: 1.4;
    }

    /* Edit Tasks toggle button */
    .btn-edit-tasks {
        border: 2px solid #fd7e14;
        color: #fd7e14;
        background: transparent;
        border-radius: 999px;
        padding: 4px 14px;
        font-size: 0.82rem;
        font-weight: 600;
        transition: background 0.18s ease, color 0.18s ease;
        cursor: pointer;
    }
    .btn-edit-tasks:hover { background: rgba(253,126,20,0.08); }
    .btn-edit-tasks.active {
        background: #dc3545;
        border-color: #dc3545;
        color: white;
    }
    .btn-edit-tasks.active:hover {
        background: #bb2d3b;
        border-color: #bb2d3b;
    }

    /* Empty state inside task log card */
    .task-empty {
        color: #aaa;
        font-style: italic;
        font-size: 0.88rem;
        padding: 14px 0 4px;
    }
</style>

<div class="home-dashboard">

@if (TempData["StatusMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show status-auto-dismiss" role="alert">
        @TempData["StatusMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@* ── WELCOME HEADER ───────────────────────────────────────── *@
<div class="home-welcome dashboard-heading mb-4">
    <div>
        <p class="dashboard-kicker">Your care dashboard</p>
        <h1>Good to see you, @Model.UserName.</h1>
        <p>Everything your pets need today, in one calm view.</p>
    </div>
    <div class="dashboard-date">@DateTime.Today.ToString("dddd, MMMM d")</div>
</div>

@* ── YOUR PETS ────────────────────────────────────────────── *@
<div class="d-flex align-items-center justify-content-between dashboard-section-heading mb-3">
    <div><p class="dashboard-kicker mb-1">AT A GLANCE</p><h2 class="mb-0 fw-semibold">Your pets</h2></div>
    <button type="button" class="btn btn-primary btn-sm"
            style="border-radius: 999px; padding: 6px 18px; font-weight: 600;"
            data-bs-toggle="modal" data-bs-target="#addPetModal">
        + Add Pet
    </button>
</div>

@if (Model.Pets.Count == 0)
{
    <div class="alert mb-4"
         style="border: 2px solid var(--pet-secondary); border-radius: 12px; color: var(--pet-dark); background: rgba(244,164,96,0.08);">
        No pets yet — click <strong>+ Add Pet</strong> to get started!
    </div>
}
else
{
    <div class="row g-3 mb-4">
        @foreach (var pet in Model.Pets)
        {
            var petBirthdate = pet.Birthdate.ToString("yyyy-MM-dd");
            string petEmoji = pet.Type?.ToLower() switch {
                "cat"    => "🐱",
                "dog"    => "🐕",
                "bird"   => "🐦",
                "fish"   => "🐟",
                "rabbit" => "🐰",
                _        => "🐾"
            };
            string birthdateDisplay = pet.Birthdate != default
                ? pet.Birthdate.ToString("MMM d, yyyy")
                : "—";
            var quickLogTasks = Model.PetAllTasks[pet.PetID];
            string lastPeeLabel = PetPotty.Pages.HomeModel.LastActivityLabel(quickLogTasks, "Pee");
            string lastPoopLabel = PetPotty.Pages.HomeModel.LastActivityLabel(quickLogTasks, "Poop");

            <div class="col-md-6 col-xxl-4">
                <div class="pet-card">

                    @* Hover-reveal edit pencil *@
                    <button class="pet-card-edit-btn edit-pet-btn"
                            data-bs-toggle="modal"
                            data-bs-target="#editPetModal"
                            data-pet-id="@pet.PetID"
                            data-pet-name="@pet.Name"
                            data-pet-type="@pet.Type"
                            data-pet-breed="@pet.Breed"
                            data-pet-age="@pet.Age"
                            data-pet-birthdate="@petBirthdate"
                            data-pet-gender="@pet.Gender"
                            data-pet-image="@pet.ProfileImagePath"
                            data-pet-emoji="@petEmoji"
                            title="Edit @pet.Name">
                        ✏️
                    </button>

                    @* Avatar + info *@
                    <div class="d-flex align-items-center gap-3 mb-3">
                        <div class="pet-avatar">
                            @if (!string.IsNullOrWhiteSpace(pet.ProfileImagePath))
                            {
                                <img src="@pet.ProfileImagePath" alt="@pet.Name profile photo"
                                     onerror="this.style.display='none'; this.nextElementSibling.style.display='inline';" />
                                <span style="display:none">@petEmoji</span>
                            }
                            else
                            {
                                <span>@petEmoji</span>
                            }
                        </div>
                        <div>
                            <div class="d-flex align-items-center gap-2 flex-wrap">
                                <span class="fw-bold" style="font-size: 1.1rem; color: var(--pet-dark);">@pet.Name</span>
                                <span class="badge"
                                      style="background: rgba(244,164,96,0.25); color: var(--pet-primary); font-weight: 600; font-size: 0.72rem; border-radius: 999px; padding: 2px 9px;">
                                    @pet.Type
                                </span>
                            </div>
                            @if (!string.IsNullOrWhiteSpace(pet.Breed))
                            {
                                <div class="text-muted" style="font-size: 0.85rem;">@pet.Breed</div>
                            }
                            <div style="font-size: 0.82rem; color: #888;">
                                @(!string.IsNullOrWhiteSpace(pet.Age) ? pet.Age + " yrs" : "")
                                @(!string.IsNullOrWhiteSpace(pet.Age) && !string.IsNullOrWhiteSpace(pet.Gender) ? " • " : "")
                                @pet.Gender
                            </div>
                            @if (pet.Birthdate != default)
                            {
                                <div style="font-size: 0.8rem; color: #aaa;">🎂 @birthdateDisplay</div>
                            }
                        </div>
                    </div>

                    @* Quick-log buttons *@
                    <div class="d-flex gap-2 mb-3">
                        <form method="post" asp-page-handler="QuickLog"
                              class="quick-log-form flex-fill">
                            <input type="hidden" name="petID" value="@pet.PetID" />
                            <input type="hidden" name="taskType" value="Pee" />
                            <div class="quick-log-label">@lastPeeLabel</div>
                            <input type="hidden" name="localTime" />
                            <button type="submit" class="quick-log-pill w-100"><span class="quick-log-icon">💧</span>Pee</button>
                        </form>
                        <form method="post" asp-page-handler="QuickLog"
                              class="quick-log-form flex-fill">
                            <input type="hidden" name="petID" value="@pet.PetID" />
                            <input type="hidden" name="taskType" value="Poop" />
                            <div class="quick-log-label">@lastPoopLabel</div>
                            <input type="hidden" name="localTime" />
                            <button type="submit" class="quick-log-pill w-100"><span class="quick-log-icon">💩</span>Poop</button>
                        </form>
                    </div>

                    @* Add Task *@
                    <button type="button"
                            class="add-task-card-btn add-task-btn"
                            data-bs-toggle="modal"
                            data-bs-target="#addTaskModal"
                            data-pet-id="@pet.PetID"
                            data-pet-name="@pet.Name">
                        + Add Task
                    </button>

                </div>
            </div>
        }
    </div>
}

@* ── TASK LOG ─────────────────────────────────────────────── *@
<div class="d-flex align-items-center justify-content-between dashboard-section-heading task-log-heading mb-3">
    <div class="d-flex align-items-center gap-3">
        <div><p class="dashboard-kicker mb-1">WHAT JUST HAPPENED</p><h2 class="mb-0 fw-semibold">Recent activity</h2></div>
        <div class="seg-toggle" role="group" aria-label="Task log range">
            <form method="post" asp-page-handler="SetTaskView">
                <input type="hidden" name="showAllTime" value="false" />
                <button type="submit" class="seg-option @(!Model.ShowAllTime ? "seg-active" : "")">Recent</button>
            </form>
            <form method="post" asp-page-handler="SetTaskView">
                <input type="hidden" name="showAllTime" value="true" />
                <button type="submit" class="seg-option @(Model.ShowAllTime ? "seg-active" : "")">All Time</button>
            </form>
        </div>
    </div>
    <button type="button" class="btn-edit-tasks" id="toggleTaskActionsBtn" aria-pressed="false">
        ✏️ Edit Tasks
    </button>
</div>

@if (Model.Pets.Count == 0)
{
    <p class="text-muted fst-italic">Add a pet to start logging tasks.</p>
}
else
{
    <div class="row g-3">
        @foreach (var pet in Model.Pets)
        {
            string petLogEmoji = pet.Type?.ToLower() switch {
                "cat"    => "🐱",
                "dog"    => "🐕",
                "bird"   => "🐦",
                "rabbit" => "🐰",
                _        => "🐾"
            };
            var tasks = Model.PetTasks[pet.PetID];
            var taskLogCollapseId = $"taskLog{pet.PetID}";

            <div class="col-md-6">
                <div class="task-log-card">
                    <div class="task-log-card-header">
                        <button class="task-log-toggle"
                                type="button"
                                data-bs-toggle="collapse"
                                data-bs-target="#@taskLogCollapseId"
                                aria-expanded="true"
                                aria-controls="@taskLogCollapseId">
                            <span>@petLogEmoji @pet.Name's log</span>
                            <span class="task-log-caret" aria-hidden="true">^</span>
                        </button>
                    </div>
                    <div id="@taskLogCollapseId" class="collapse show">
                        <div class="task-log-card-body">
                            @if (tasks.Count == 0)
                            {
                                <p class="task-empty">No tasks logged yet.</p>
                            }
                            else
                            {
                                DateTime? prevDate = null;
                                @foreach (var task in tasks)
                                {
                                    var taskDateValue = task.CreatedAt.ToString("yyyy-MM-dd");
                                    bool isNewDay = prevDate == null || task.CreatedAt.Date != prevDate.Value.Date;
                                    if (isNewDay)
                                    {
                                        var dayLabel = task.CreatedAt.ToString("dddd, MMM d");

                                        <div><span class="task-date-pill" data-task-date="@taskDateValue">@dayLabel</span></div>
                                    }
                                    prevDate = task.CreatedAt.Date;

                                    string taskEmoji = task.TaskType switch {
                                        "Pee"       => "💧",
                                        "Poop"      => "💩",
                                        "Pee & Poop"=> "💧💩",
                                        "Walk"      => "🦮",
                                        "Play"      => "🎾",
                                        "Food"      => "🍽️",
                                        "Water"     => "🥤",
                                        _           => "📋"
                                    };
                                    var createdAtInputValue = task.CreatedAt.ToString("yyyy-MM-ddTHH:mm");

                                    <div class="task-row">
                                        <div class="task-icon">@taskEmoji</div>
                                        <div class="flex-grow-1 min-width-0">
                                            <div class="d-flex align-items-center justify-content-between gap-2">
                                                <span class="fw-semibold" style="font-size: 0.92rem; color: var(--pet-dark);">
                                                    @task.TaskType
                                                </span>
                                                <div class="d-flex align-items-center gap-2 flex-shrink-0">
                                                    <span class="text-muted" style="font-size: 0.82rem; white-space: nowrap;">
                                                        @task.CreatedAt.ToString("h:mm tt")
                                                    </span>
                                                    <button class="btn btn-sm btn-edit edit-task-btn task-actions-col d-none"
                                                            data-bs-toggle="modal"
                                                            data-bs-target="#editTaskModal"
                                                            data-task-id="@task.TaskID"
                                                            data-task-type="@task.TaskType"
                                                            data-task-notes="@task.Notes"
                                                            data-task-created="@createdAtInputValue">
                                                        ✏️
                                                    </button>
                                                </div>
                                            </div>
                                            @if (!string.IsNullOrWhiteSpace(task.Notes))
                                            {
                                                <div class="text-muted" style="font-size: 0.8rem; margin-top: 2px;">
                                                    @task.Notes
                                                </div>
                                            }
                                        </div>
                                    </div>
                                }
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}

</div>

@* ── MODALS ──────────────────────────────────────────────── *@
@section Modals {

    @* ADD PET MODAL *@
    <div class="modal fade" id="addPetModal" tabindex="-1" aria-labelledby="addPetModalLabel" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="addPetModalLabel">🐾 Add New Pet</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <form method="post" asp-page-handler="AddPet" enctype="multipart/form-data" id="addPetForm">
                    <div class="modal-body">
                        @if (Model.ModalToOpen == "addPetModal" && Model.PetImageError != null)
                        {
                            <div class="alert alert-danger" role="alert">@Model.PetImageError</div>
                        }
                        <div class="pet-image-preview" id="addPetImagePreview">
                            <img alt="Selected pet photo preview" />
                            <span>🐾</span>
                        </div>
                        <div class="mb-3">
                            <label asp-for="NewPetImage" class="form-label">Profile picture <span class="text-muted">(optional)</span></label>
                            <input asp-for="NewPetImage" type="file" class="form-control pet-image-input"
                                   accept="image/jpeg,image/png,.jpg,.jpeg,.png" data-preview="addPetImagePreview" />
                            <div class="form-text">JPEG or PNG, up to 2 MB.</div>
                            <div class="invalid-feedback pet-image-client-error"></div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Name</label>
                            <input asp-for="NewPetName" class="form-control" required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Type</label>
                            <select asp-for="NewPetType" class="form-select" required>
                                <option value="">-- Select --</option>
                                <option>Dog</option>
                                <option>Cat</option>
                                <option>Bird</option>
                                <option>Rabbit</option>
                                <option>Fish</option>
                                <option>Other</option>
                            </select>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Breed</label>
                            <input asp-for="NewPetBreed" class="form-control" />
                        </div>
                        <div class="row">
                            <div class="col mb-3">
                                <label class="form-label">Age</label>
                                <input asp-for="NewPetAge" class="form-control" id="NewPetAge" placeholder="e.g. 3" />
                            </div>
                            <div class="col mb-3">
                                <label class="form-label">Gender</label>
                                <select asp-for="NewPetGender" class="form-select">
                                    <option value="">-- Select --</option>
                                    <option>Male</option>
                                    <option>Female</option>
                                </select>
                            </div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Birthdate</label>
                            <input asp-for="NewPetBirthdate" type="date" class="form-control" id="NewPetBirthdate" />
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-primary">Add Pet</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    @* EDIT PET MODAL *@
    <div class="modal fade" id="editPetModal" tabindex="-1" aria-labelledby="editPetModalLabel" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="editPetModalLabel">✏️ Edit Pet</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <form method="post" asp-page-handler="EditPet" enctype="multipart/form-data" id="editPetForm">
                    <input type="hidden" asp-for="EditPetID" id="editPetID" />
                    <div class="modal-body">
                        @if (Model.ModalToOpen == "editPetModal" && Model.PetImageError != null)
                        {
                            <div class="alert alert-danger" role="alert">@Model.PetImageError</div>
                        }
                        <div class="pet-image-preview" id="editPetImagePreview">
                            <img alt="Current pet profile photo" />
                            <span>🐾</span>
                        </div>
                        <div class="mb-3">
                            <label asp-for="EditPetImage" class="form-label">Replace profile picture <span class="text-muted">(optional)</span></label>
                            <input asp-for="EditPetImage" type="file" class="form-control pet-image-input"
                                   accept="image/jpeg,image/png,.jpg,.jpeg,.png" data-preview="editPetImagePreview" />
                            <div class="form-text">JPEG or PNG, up to 2 MB.</div>
                            <div class="invalid-feedback pet-image-client-error"></div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Name</label>
                            <input asp-for="EditPetName" class="form-control" id="editPetName" required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Type</label>
                            <select asp-for="EditPetType" class="form-select" id="editPetType">
                                <option value="">-- Select --</option>
                                <option>Dog</option>
                                <option>Cat</option>
                                <option>Bird</option>
                                <option>Rabbit</option>
                                <option>Fish</option>
                                <option>Other</option>
                            </select>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Breed</label>
                            <input asp-for="EditPetBreed" class="form-control" id="editPetBreed" />
                        </div>
                        <div class="row">
                            <div class="col mb-3">
                                <label class="form-label">Age</label>
                                <input asp-for="EditPetAge" class="form-control" id="editPetAge" />
                            </div>
                            <div class="col mb-3">
                                <label class="form-label">Gender</label>
                                <select asp-for="EditPetGender" class="form-select" id="editPetGender">
                                    <option value="">-- Select --</option>
                                    <option>Male</option>
                                    <option>Female</option>
                                </select>
                            </div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Birthdate</label>
                            <input asp-for="EditPetBirthdate" type="date" class="form-control" id="editPetBirthdate" />
                        </div>
                    </div>
                </form>

                <form method="post" asp-page-handler="DeletePet" id="deletePetForm">
                    <input type="hidden" name="EditPetID" id="deletePetID" />
                </form>

                <div class="modal-footer d-flex justify-content-between">
                    <button type="submit" form="deletePetForm" class="btn btn-danger"
                            onclick="return confirm('Delete this pet and all their tasks?');">
                        Delete Pet
                    </button>
                    <div>
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" form="editPetForm" class="btn btn-warning">Save Changes</button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @* ADD TASK MODAL *@
    <div class="modal fade" id="addTaskModal" tabindex="-1" aria-labelledby="addTaskModalLabel" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="addTaskModalLabel">
                        Add Task for <span id="addTaskPetName"></span>
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <form method="post" asp-page-handler="AddTask">
                    <input type="hidden" name="NewTaskPetID" id="newTaskPetID" />
                    <div class="modal-body">
                        <div class="mb-3">
                            <label class="form-label">Task Type</label>
                            <select name="NewTaskType" class="form-select" required>
                                <option value="">-- Select --</option>
                                <option>Pee</option>
                                <option>Poop</option>
                                <option>Pee & Poop</option>
                                <option>Food</option>
                                <option>Water</option>
                                <option>Walk</option>
                                <option>Play</option>
                                <option>Other</option>
                            </select>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Date & Time</label>
                            <input type="datetime-local" name="NewTaskCreatedAt" id="newTaskCreatedAt"
                                   class="form-control" required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Notes</label>
                            <textarea name="NewTaskNotes" class="form-control" rows="3"
                                      placeholder="Optional notes..."></textarea>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-success">Add Task</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    @* EDIT TASK MODAL *@
    <div class="modal fade" id="editTaskModal" tabindex="-1" aria-labelledby="editTaskModalLabel" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="editTaskModalLabel">✏️ Edit Task</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <form method="post" asp-page-handler="UpdateTask" id="editTaskForm">
                    <input type="hidden" name="UpdateTaskID" id="editTaskID" />
                    <div class="modal-body">
                        <div class="mb-3">
                            <label class="form-label">Task Type</label>
                            <select name="UpdateTaskType" id="editTaskType" class="form-select" required>
                                <option value="">-- Select --</option>
                                <option>Pee</option>
                                <option>Poop</option>
                                <option>Pee & Poop</option>
                                <option>Food</option>
                                <option>Water</option>
                                <option>Walk</option>
                                <option>Play</option>
                                <option>Other</option>
                            </select>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Date & Time</label>
                            <input type="datetime-local" name="UpdateTaskCreatedAt" id="editTaskCreatedAt"
                                   class="form-control" required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Notes</label>
                            <textarea name="UpdateTaskNotes" id="editTaskNotes" class="form-control" rows="3"
                                      placeholder="Optional notes..."></textarea>
                        </div>
                    </div>
                </form>
                <form method="post" asp-page-handler="DeleteTask" id="deleteTaskForm">
                    <input type="hidden" name="taskID" id="deleteTaskID" />
                </form>
                <div class="modal-footer d-flex justify-content-between">
                    <button type="submit" form="deleteTaskForm" class="btn btn-danger"
                            onclick="return confirm('Delete this task?');">
                        Delete Task
                    </button>
                    <div>
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" form="editTaskForm" class="btn btn-success">Update Task</button>
                    </div>
                </div>
            </div>
        </div>
    </div>

} @* end @section Modals *@

@section Scripts {
    <script>
        const statusBanner = document.querySelector('.status-auto-dismiss');
        if (statusBanner) {
            setTimeout(() => {
                bootstrap.Alert.getOrCreateInstance(statusBanner).close();
            }, 10000);
        }

        const modalToOpen = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.ModalToOpen));
        if (modalToOpen) {
            bootstrap.Modal.getOrCreateInstance(document.getElementById(modalToOpen)).show();
        }

        function setPetImagePreview(previewID, imagePath, emoji) {
            const preview = document.getElementById(previewID);
            const image = preview.querySelector('img');
            const fallback = preview.querySelector('span');
            image.onload = () => {
                image.style.display = 'block';
                fallback.style.display = 'none';
            };
            image.onerror = () => {
                image.style.display = 'none';
                image.removeAttribute('src');
                fallback.style.display = 'inline';
            };
            fallback.textContent = emoji || '🐾';
            if (imagePath) image.src = imagePath;
            else image.onerror();
        }

        if (modalToOpen === 'editPetModal') {
            const currentEditImage = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.EditPetCurrentImagePath));
            setPetImagePreview('editPetImagePreview', currentEditImage, '🐾');
        }

        document.querySelectorAll('.pet-image-input').forEach(input => {
            input.addEventListener('change', function () {
                const file = this.files[0];
                const error = this.parentElement.querySelector('.pet-image-client-error');
                this.classList.remove('is-invalid');
                error.textContent = '';
                if (!file) return;

                if (file.size > 2 * 1024 * 1024) {
                    this.value = '';
                    this.classList.add('is-invalid');
                    error.textContent = 'The pet photo must be 2 MB or smaller.';
                    return;
                }
                if (!['image/jpeg', 'image/png'].includes(file.type)) {
                    this.value = '';
                    this.classList.add('is-invalid');
                    error.textContent = 'Only JPEG and PNG pet photos are allowed.';
                    return;
                }

                setPetImagePreview(this.dataset.preview, URL.createObjectURL(file), '🐾');
            });
        });

        function formatLocalDateKey(date) {
            return date.getFullYear() + '-' +
                String(date.getMonth() + 1).padStart(2, '0') + '-' +
                String(date.getDate()).padStart(2, '0');
        }

        document.querySelectorAll('.task-date-pill[data-task-date]').forEach(pill => {
            const taskDate = pill.dataset.taskDate;
            const today = new Date();
            const yesterday = new Date(today);
            yesterday.setDate(today.getDate() - 1);

            if (taskDate === formatLocalDateKey(today)) {
                pill.textContent = 'Today';
                return;
            }

            if (taskDate === formatLocalDateKey(yesterday)) {
                pill.textContent = 'Yesterday';
                return;
            }

            const [year, month, day] = taskDate.split('-').map(Number);
            const localDate = new Date(year, month - 1, day);
            pill.textContent = localDate.toLocaleDateString(undefined, {
                weekday: 'long',
                month: 'short',
                day: 'numeric'
            });
        });

        // ── Edit Tasks toggle — show/hide ✏️ pencil buttons in task rows ──
        const toggleTaskActionsBtn = document.getElementById('toggleTaskActionsBtn');
        if (toggleTaskActionsBtn) {
            toggleTaskActionsBtn.addEventListener('click', function () {
                const isActive = this.classList.toggle('active');
                this.setAttribute('aria-pressed', isActive ? 'true' : 'false');
                document.querySelectorAll('.task-actions-col').forEach(el => {
                    el.classList.toggle('d-none', !isActive);
                });
            });
        }

        // ── Quick log — inject client local time before submit ──
        document.querySelectorAll('.quick-log-form').forEach(form => {
            form.addEventListener('submit', function () {
                const now = new Date();
                const local = formatLocalDateKey(now) + 'T' +
                    String(now.getHours()).padStart(2, '0') + ':' +
                    String(now.getMinutes()).padStart(2, '0') + ':' +
                    String(now.getSeconds()).padStart(2, '0');
                this.querySelector('input[name="localTime"]').value = local;
            });
        });

        // ── Birthdate → Age auto-calc ──
        function calcAge(birthdateValue) {
            if (!birthdateValue) return '';
            const birth = new Date(birthdateValue + 'T00:00:00');
            const today = new Date();
            let age = today.getFullYear() - birth.getFullYear();
            const m = today.getMonth() - birth.getMonth();
            if (m < 0 || (m === 0 && today.getDate() < birth.getDate())) age--;
            return age >= 0 ? String(age) : '';
        }

        const newBirthdate = document.getElementById('NewPetBirthdate');
        const newAge       = document.getElementById('NewPetAge');
        if (newBirthdate) newBirthdate.addEventListener('change', () => { newAge.value = calcAge(newBirthdate.value); });

        const editBirthdate = document.getElementById('editPetBirthdate');
        const editAge       = document.getElementById('editPetAge');
        if (editBirthdate) editBirthdate.addEventListener('change', () => { editAge.value = calcAge(editBirthdate.value); });

        // ── Edit Pet modal — populate from data attributes ──
        document.querySelectorAll('.edit-pet-btn').forEach(button => {
            button.addEventListener('click', function () {
                document.getElementById('editPetID').value        = this.dataset.petId;
                document.getElementById('deletePetID').value      = this.dataset.petId;
                document.getElementById('editPetName').value      = this.dataset.petName;
                document.getElementById('editPetType').value      = this.dataset.petType;
                document.getElementById('editPetBreed').value     = this.dataset.petBreed;
                document.getElementById('editPetAge').value       = this.dataset.petAge;
                document.getElementById('editPetBirthdate').value = this.dataset.petBirthdate;
                document.getElementById('editPetGender').value    = this.dataset.petGender;
                document.getElementById('EditPetImage').value     = '';
                setPetImagePreview('editPetImagePreview', this.dataset.petImage, this.dataset.petEmoji);
            });
        });

        // ── Edit Task modal — populate from data attributes ──
        document.querySelectorAll('.edit-task-btn').forEach(button => {
            button.addEventListener('click', function () {
                document.getElementById('editTaskID').value        = this.dataset.taskId;
                document.getElementById('editTaskType').value      = this.dataset.taskType;
                document.getElementById('editTaskNotes').value     = this.dataset.taskNotes || '';
                document.getElementById('editTaskCreatedAt').value = this.dataset.taskCreated;
                document.getElementById('deleteTaskID').value      = this.dataset.taskId;
            });
        });

        // ── Add Task modal — set pet ID/name and default datetime ──
        document.querySelectorAll('.add-task-btn').forEach(button => {
            button.addEventListener('click', function () {
                document.getElementById('newTaskPetID').value          = this.dataset.petId;
                document.getElementById('addTaskPetName').textContent  = this.dataset.petName;
                const now = new Date();
                const formatted = formatLocalDateKey(now) + 'T' +
                    String(now.getHours()).padStart(2, '0') + ':' +
                    String(now.getMinutes()).padStart(2, '0');
                document.getElementById('newTaskCreatedAt').value = formatted;
            });
        });
    </script>
}
