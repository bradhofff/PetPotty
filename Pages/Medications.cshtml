@page
@model PetPotty.Pages.MedicationsModel
@{
    ViewData["Title"] = "Medications";
}

<style>
    .med-card {
        border: 2px solid var(--pet-secondary);
        border-radius: 14px;
        box-shadow: 0 2px 10px rgba(139,69,19,0.07);
    }

    .med-card-edit-btn {
        position: absolute;
        top: 12px;
        right: 12px;
        width: 32px;
        height: 32px;
        border-radius: 50%;
        border: 2px solid #fd7e14;
        color: #fd7e14;
        background: white;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.82rem;
        opacity: 0;
        transition: opacity 0.18s ease, background 0.18s ease, color 0.18s ease;
        cursor: pointer;
        padding: 0;
        line-height: 1;
        z-index: 2;
    }

    .med-card:hover .med-card-edit-btn,
    .med-card-edit-btn:focus {
        opacity: 1;
    }

    .med-card-edit-btn:hover {
        background: #fd7e14;
        color: white;
    }
</style>

@if (TempData["StatusMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["StatusMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@* ── PAGE HEADER ─────────────────────────────────────────── *@
<div class="mb-4">
    <h1 class="mb-1 fw-bold" style="color: var(--pet-dark);">💊 Medications</h1>
    <p class="text-muted mb-0" style="font-size: 1.05rem;">Keep every dose on track.</p>
</div>

@* ── PET SELECTOR ────────────────────────────────────────── *@
<div class="card mb-4" style="border: 2px solid var(--pet-secondary); border-radius: 14px; box-shadow: 0 2px 10px rgba(139,69,19,0.08);">
    <div class="card-body py-3 px-4">
        <form method="post" asp-page-handler="SelectPet">
            <div class="row align-items-center g-3">
                <div class="col-auto">
                    <label class="form-label fw-semibold mb-0" style="color: var(--pet-dark); font-size: 0.95rem;">
                        🐾 Choose a pet
                    </label>
                </div>
                <div class="col-md-4">
                    <select name="selectedPetID" class="form-select" onchange="this.form.submit()"
                            style="border-radius: 30px; border: 2px solid var(--pet-secondary);">
                        <option value="0">-- Select a Pet --</option>
                        @foreach (var pet in Model.Pets)
                        {
                            string petEmoji = pet.Type?.ToLower() switch {
                                "cat"   => "🐱",
                                "dog"   => "🐕",
                                "bird"  => "🐦",
                                "fish"  => "🐟",
                                "rabbit"=> "🐰",
                                _       => "🐾"
                            };
                            string label = string.IsNullOrWhiteSpace(pet.Breed)
                                ? $"{petEmoji} {pet.Name}"
                                : $"{petEmoji} {pet.Name} — {pet.Breed}";
                            <option value="@pet.PetID" selected="@(Model.SelectedPetID == pet.PetID)">
                                @label
                            </option>
                        }
                    </select>
                </div>
            </div>
        </form>
    </div>
</div>

@if (Model.SelectedPetID > 0)
{
    var selectedPet = Model.Pets.FirstOrDefault(p => p.PetID == Model.SelectedPetID);

    @* ── MEDICATIONS SECTION ─────────────────────────────────── *@
    <div class="d-flex align-items-center justify-content-between mb-3">
        <h2 class="mb-0 fw-semibold" style="color: var(--pet-dark); font-size: 1.35rem;">
            @selectedPet?.Name's Medications
        </h2>
        <button type="button"
                class="btn btn-primary"
                style="border-radius: 30px; padding: 8px 22px; font-weight: 600;"
                data-bs-toggle="modal" data-bs-target="#addMedModal">
            + Add Medication
        </button>
    </div>

    @if (Model.Medications.Count == 0)
    {
        <div class="alert mb-4" style="border: 2px solid var(--pet-secondary); border-radius: 12px; color: var(--pet-dark); background: rgba(244,164,96,0.08);">
            No medications found for @selectedPet?.Name. Click <strong>+ Add Medication</strong> to get started.
        </div>
    }
    else
    {
        @* ── MEDICATION CARDS ────────────────────────────────────── *@
        <div class="row g-3 mb-4">
            @foreach (var med in Model.Medications)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="card h-100 position-relative med-card">
                        <button class="med-card-edit-btn edit-med-btn"
                                data-bs-toggle="modal"
                                data-bs-target="#editMedModal"
                                data-med-id="@med.MedID"
                                data-med-name="@med.MedicationName"
                                data-med-dosage="@med.Dosage"
                                data-med-frequency-type="@med.FrequencyType"
                                data-med-frequency-interval="@med.FrequencyInterval"
                                data-med-start-date="@med.StartDate.ToString("yyyy-MM-ddTHH:mm")"
                                data-med-end-date="@(med.EndDate.HasValue ? med.EndDate.Value.ToString("yyyy-MM-ddTHH:mm") : "")"
                                data-med-notes="@med.Notes"
                                title="Edit @med.MedicationName">
                            ✏️
                        </button>

                        <div class="card-body pb-3 pt-3 pe-3" style="padding-left: 1.25rem;">
                            @* Medication name *@
                            <h5 class="fw-bold mb-1 pe-5" style="color: var(--pet-dark); font-size: 1.1rem;">
                                @med.MedicationName
                            </h5>
                            @* Dosage *@
                            <p class="mb-2 text-muted" style="font-size: 0.92rem;">@med.Dosage</p>

                            @* Meta rows *@
                            <div style="font-size: 0.88rem; color: #555;">
                                <div class="d-flex align-items-start mb-1">
                                    <span class="fw-semibold me-2" style="min-width: 80px; color: var(--pet-dark);">Frequency</span>
                                    <span>@med.FrequencyDisplay</span>
                                </div>
                                <div class="d-flex align-items-start mb-1">
                                    <span class="fw-semibold me-2" style="min-width: 80px; color: var(--pet-dark);">Start</span>
                                    <span>@med.StartDate.ToString("MMM d, yyyy")</span>
                                </div>
                                <div class="d-flex align-items-start mb-2">
                                    <span class="fw-semibold me-2" style="min-width: 80px; color: var(--pet-dark);">End</span>
                                    @if (med.EndDate.HasValue)
                                    {
                                        <span>@med.EndDate.Value.ToString("MMM d, yyyy")</span>
                                    }
                                    else
                                    {
                                        <span class="fw-semibold" style="color: var(--pet-accent);">Forever</span>
                                    }
                                </div>
                            </div>

                            @* Notes *@
                            @if (!string.IsNullOrWhiteSpace(med.Notes))
                            {
                                <p class="mb-0 fst-italic" style="font-size: 0.84rem; color: #888; border-top: 1px solid rgba(244,164,96,0.4); padding-top: 8px;">
                                    @med.Notes
                                </p>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>

        @* ── SCHEDULE SECTION ────────────────────────────────────── *@
        <div class="d-flex align-items-center justify-content-between mb-3">
            <h2 class="mb-0 fw-semibold" style="color: var(--pet-dark); font-size: 1.2rem;">
                📅 Medication Schedule
            </h2>
            <div class="seg-toggle">
                <form method="post" asp-page-handler="SetScheduleView">
                    <input type="hidden" name="showAllTime" value="false" />
                    <button type="submit" class="seg-option @(!Model.ShowAllTime ? "seg-active" : "")">30 Days</button>
                </form>
                <form method="post" asp-page-handler="SetScheduleView">
                    <input type="hidden" name="showAllTime" value="true" />
                    <button type="submit" class="seg-option @(Model.ShowAllTime ? "seg-active" : "")">All Time</button>
                </form>
            </div>
        </div>

        @if (Model.Schedule.Count == 0)
        {
            <div class="alert" style="border: 2px solid var(--pet-secondary); border-radius: 12px; color: var(--pet-dark); background: rgba(244,164,96,0.08);">
                No scheduled doses found for this period.
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table" style="border-radius: 12px; overflow: hidden;">
                    <thead>
                        <tr>
                            <th>Medication</th>
                            <th>Scheduled</th>
                            <th class="text-center">Dosage Given?</th>
                            <th>Dosage At</th>
                            <th class="text-center">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var s in Model.Schedule)
                        {
                            var logDateStr = s.ScheduleDate.ToString("yyyy-MM-ddTHH:mm:ss");
                            <tr>
                                <td class="fw-semibold">@s.MedicationName</td>
                                <td>@s.ScheduleDate.ToString("MMM d, h:mm tt")</td>
                                <td class="text-center">
                                    @if (s.IsConfirmed)
                                    {
                                        <span class="fw-semibold" style="color: var(--pet-success);">✓ Yes</span>
                                    }
                                    else
                                    {
                                        <span class="fw-semibold" style="color: #dc3545;">✕ No</span>
                                    }
                                </td>
                                <td style="color: #666; font-size: 0.9rem;">
                                    @(s.ConfirmedAt.HasValue ? s.ConfirmedAt.Value.ToString("MMM d, h:mm tt") : "—")
                                </td>
                                <td class="text-center">
                                    @if (!s.IsConfirmed)
                                    {
                                        <button type="button"
                                                class="btn btn-sm btn-success confirm-dose-btn"
                                                style="border-radius: 20px; padding: 4px 14px; font-size: 0.82rem;"
                                                data-bs-toggle="modal"
                                                data-bs-target="#confirmDoseModal"
                                                data-med-id="@s.MedID"
                                                data-med-name="@s.MedicationName"
                                                data-log-date="@logDateStr"
                                                data-scheduled-display="@s.ScheduleDate.ToString("MMM d, h:mm tt")">
                                            ✔ Confirm Dose
                                        </button>
                                    }
                                    else
                                    {
                                        <form method="post" asp-page-handler="UnconfirmSchedule"
                                              style="display:inline">
                                            <input type="hidden" name="medID" value="@s.MedID" />
                                            <input type="hidden" name="logDate" value="@logDateStr" />
                                            <button class="btn btn-sm"
                                                    style="border-radius: 20px; padding: 4px 14px; font-size: 0.82rem; border: 2px solid #6c757d; color: #6c757d; background: transparent;"
                                                    onclick="return confirm('Undo confirm for this dose?');">
                                                ↩ Undo
                                            </button>
                                        </form>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    }
}
else
{
    <div class="text-center py-5 text-muted">
        <div style="font-size: 4rem; margin-bottom: 1rem;">💊</div>
        <h4 style="color: var(--pet-dark);">Select a pet to manage their medications</h4>
        <p class="text-muted">Choose from the dropdown above to get started.</p>
    </div>
}

@* ── MODALS ──────────────────────────────────────────────── *@
@section Modals {

    @* ADD MEDICATION MODAL *@
    <div class="modal fade" id="addMedModal" tabindex="-1" aria-labelledby="addMedModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="addMedModalLabel">➕ Add Medication</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <form method="post" asp-page-handler="AddMedication">
                    <input type="hidden" name="SelectedPetID" value="@Model.SelectedPetID" />
                    <div class="modal-body">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label fw-semibold">Medication Name <span class="text-danger">*</span></label>
                                <input asp-for="NewMedName" class="form-control" placeholder="e.g. Apoquel" required />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-semibold">Dosage <span class="text-danger">*</span></label>
                                <input asp-for="NewMedDosage" class="form-control" placeholder="e.g. 10mg" required />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-semibold">Frequency Type <span class="text-danger">*</span></label>
                                <select asp-for="NewMedFrequencyType" class="form-select" required>
                                    <option value="">-- Select --</option>
                                    <option>Hourly</option>
                                    <option>Daily</option>
                                    <option>Weekly</option>
                                    <option>Monthly</option>
                                </select>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-semibold">
                                    Interval
                                    <span class="text-muted fw-normal">(e.g. every X hours/days)</span>
                                </label>
                                <input asp-for="NewMedFrequencyInterval" type="number" min="1"
                                       class="form-control" placeholder="e.g. 8" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-semibold">Start Date & Time <span class="text-danger">*</span></label>
                                <input asp-for="NewMedStartDate" type="datetime-local"
                                       id="newMedStartDate" class="form-control" required />
                            </div>
                            <div class="col-md-6 d-flex flex-column justify-content-end">
                                <div class="form-check mb-2">
                                    <input asp-for="NewMedForever" class="form-check-input" type="checkbox"
                                           id="newMedForever" checked />
                                    <label class="form-check-label fw-semibold" for="newMedForever">
                                        Forever? <span class="text-muted fw-normal">(no end date)</span>
                                    </label>
                                </div>
                                <div id="newMedEndDateWrapper" class="d-none">
                                    <label class="form-label fw-semibold">
                                        End Date & Time <span class="text-danger">*</span>
                                    </label>
                                    <input asp-for="NewMedEndDate" type="datetime-local"
                                           id="newMedEndDate" class="form-control" />
                                </div>
                            </div>
                            <div class="col-12">
                                <label class="form-label fw-semibold">Notes</label>
                                <textarea asp-for="NewMedNotes" class="form-control" rows="2"
                                          placeholder="Optional notes..."></textarea>
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-primary">Add Medication</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    @* EDIT MEDICATION MODAL *@
    <div class="modal fade" id="editMedModal" tabindex="-1" aria-labelledby="editMedModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="editMedModalLabel">✏️ Edit Medication</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <form method="post" asp-page-handler="EditMedication" id="editMedForm">
                    <input type="hidden" asp-for="EditMedID" id="editMedID" />
                    <input type="hidden" name="SelectedPetID" value="@Model.SelectedPetID" />
                    <div class="modal-body">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label fw-semibold">Medication Name <span class="text-danger">*</span></label>
                                <input asp-for="EditMedName" class="form-control" id="editMedName" required />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-semibold">Dosage <span class="text-danger">*</span></label>
                                <input asp-for="EditMedDosage" class="form-control" id="editMedDosage" required />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-semibold">Frequency Type <span class="text-danger">*</span></label>
                                <select asp-for="EditMedFrequencyType" class="form-select" id="editMedFrequencyType" required>
                                    <option value="">-- Select --</option>
                                    <option>Hourly</option>
                                    <option>Daily</option>
                                    <option>Weekly</option>
                                    <option>Monthly</option>
                                </select>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-semibold">Interval</label>
                                <input asp-for="EditMedFrequencyInterval" type="number" min="1"
                                       class="form-control" id="editMedFrequencyInterval" placeholder="e.g. 8" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-semibold">Start Date & Time <span class="text-danger">*</span></label>
                                <input asp-for="EditMedStartDate" type="datetime-local" class="form-control"
                                       id="editMedStartDate" required />
                            </div>
                            <div class="col-md-6 d-flex flex-column justify-content-end">
                                <div class="form-check mb-2">
                                    <input asp-for="EditMedForever" class="form-check-input" type="checkbox"
                                           id="editMedForever" />
                                    <label class="form-check-label fw-semibold" for="editMedForever">
                                        Forever? <span class="text-muted fw-normal">(no end date)</span>
                                    </label>
                                </div>
                                <div id="editMedEndDateWrapper">
                                    <label class="form-label fw-semibold">
                                        End Date & Time <span class="text-danger">*</span>
                                    </label>
                                    <input asp-for="EditMedEndDate" type="datetime-local" class="form-control"
                                           id="editMedEndDate" />
                                </div>
                            </div>
                            <div class="col-12">
                                <label class="form-label fw-semibold">Notes</label>
                                <textarea asp-for="EditMedNotes" class="form-control" rows="2"
                                          id="editMedNotes" placeholder="Optional notes..."></textarea>
                            </div>
                        </div>
                    </div>
                </form>

                @* Delete form outside edit form *@
                <form method="post" asp-page-handler="DeleteMedication" id="deleteMedForm">
                    <input type="hidden" name="medID" id="deleteMedID" />
                    <input type="hidden" name="SelectedPetID" value="@Model.SelectedPetID" />
                </form>

                <div class="modal-footer d-flex justify-content-between">
                    <button type="submit" form="deleteMedForm" class="btn btn-danger"
                            onclick="return confirm('Delete this medication and all its scheduled doses?');">
                        Delete
                    </button>
                    <div>
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" form="editMedForm" class="btn btn-warning">Save Changes</button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @* CONFIRM DOSE MODAL *@
    <div class="modal fade" id="confirmDoseModal" tabindex="-1" aria-labelledby="confirmDoseModalLabel" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="confirmDoseModalLabel">Confirm Dose</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <form method="post" asp-page-handler="ConfirmSchedule">
                    <input type="hidden" name="medID" id="confirmDoseMedID" />
                    <input type="hidden" name="logDate" id="confirmDoseLogDate" />
                    <div class="modal-body">
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Medication</label>
                            <input type="text" class="form-control" id="confirmDoseMedName" readonly />
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Scheduled Dose</label>
                            <input type="text" class="form-control" id="confirmDoseScheduledDisplay" readonly />
                        </div>
                        <div>
                            <label class="form-label fw-semibold">
                                Confirmed Date & Time <span class="text-danger">*</span>
                            </label>
                            <input type="datetime-local" name="confirmedAt" id="confirmDoseConfirmedAt"
                                   class="form-control" required />
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-success">Confirm Dose</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

} @* end @section Modals *@

@section Scripts {
    <script>
        // Helper — formats a Date object to yyyy-MM-ddTHH:mm for datetime-local inputs
        function formatDateTimeLocal(d) {
            return d.getFullYear() + '-' +
                String(d.getMonth() + 1).padStart(2, '0') + '-' +
                String(d.getDate()).padStart(2, '0') + 'T' +
                String(d.getHours()).padStart(2, '0') + ':' +
                String(d.getMinutes()).padStart(2, '0');
        }

        // ── Confirm Dose modal — default confirmed time to now ──
        document.querySelectorAll('.confirm-dose-btn').forEach(button => {
            button.addEventListener('click', function () {
                document.getElementById('confirmDoseMedID').value = this.dataset.medId;
                document.getElementById('confirmDoseLogDate').value = this.dataset.logDate;
                document.getElementById('confirmDoseMedName').value = this.dataset.medName;
                document.getElementById('confirmDoseScheduledDisplay').value = this.dataset.scheduledDisplay;
                document.getElementById('confirmDoseConfirmedAt').value = formatDateTimeLocal(new Date());
            });
        });

        // ── ADD MODAL — reset on open: start = now, Forever checked, end date hidden ──
        const addMedModal = document.getElementById('addMedModal');
        if (addMedModal) {
            addMedModal.addEventListener('show.bs.modal', function () {
                const now = new Date();
                document.getElementById('newMedStartDate').value = formatDateTimeLocal(now);
                document.getElementById('newMedEndDate').value   = '';
                // Ensure Forever is checked and end date wrapper is hidden
                document.getElementById('newMedForever').checked = true;
                document.getElementById('newMedEndDateWrapper').classList.add('d-none');
                document.getElementById('newMedEndDate').removeAttribute('required');
            });
        }

        // ── Forever checkbox toggle — Add modal ──
        document.getElementById('newMedForever').addEventListener('change', function () {
            const wrapper = document.getElementById('newMedEndDateWrapper');
            const endInput = document.getElementById('newMedEndDate');
            if (this.checked) {
                wrapper.classList.add('d-none');
                endInput.value = '';
                endInput.removeAttribute('required');
            } else {
                wrapper.classList.remove('d-none');
                endInput.setAttribute('required', 'required');
            }
        });

        // ── Forever checkbox toggle — Edit modal ──
        document.getElementById('editMedForever').addEventListener('change', function () {
            const wrapper = document.getElementById('editMedEndDateWrapper');
            const endInput = document.getElementById('editMedEndDate');
            if (this.checked) {
                wrapper.classList.add('d-none');
                endInput.value = '';
                endInput.removeAttribute('required');
            } else {
                wrapper.classList.remove('d-none');
                endInput.setAttribute('required', 'required');
            }
        });

        // ── EDIT MODAL — populate all fields from data attributes ──
        document.querySelectorAll('.edit-med-btn').forEach(button => {
            button.addEventListener('click', function () {
                document.getElementById('editMedID').value                = this.dataset.medId;
                document.getElementById('deleteMedID').value              = this.dataset.medId;
                document.getElementById('editMedName').value              = this.dataset.medName;
                document.getElementById('editMedDosage').value            = this.dataset.medDosage;
                document.getElementById('editMedFrequencyType').value     = this.dataset.medFrequencyType;
                document.getElementById('editMedFrequencyInterval').value = this.dataset.medFrequencyInterval || '';
                document.getElementById('editMedNotes').value             = this.dataset.medNotes || '';

                // These come in as yyyy-MM-ddTHH:mm already — datetime-local accepts this directly
                document.getElementById('editMedStartDate').value = this.dataset.medStartDate || '';

                const endDate = this.dataset.medEndDate || '';
                const forever = !endDate;
                const foreverChk = document.getElementById('editMedForever');
                const wrapper    = document.getElementById('editMedEndDateWrapper');
                const endInput   = document.getElementById('editMedEndDate');

                foreverChk.checked = forever;
                if (forever) {
                    wrapper.classList.add('d-none');
                    endInput.value = '';
                    endInput.removeAttribute('required');
                } else {
                    wrapper.classList.remove('d-none');
                    endInput.value = endDate;
                    endInput.setAttribute('required', 'required');
                }
            });
        });
    </script>
}
